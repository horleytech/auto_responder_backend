# Required
API_KEY=your-secret-incoming-key
DASHBOARD_PASSWORD=your-dashboard-password
OPENAI_CHATGPT=your-openai-key
# OPENAI_API_KEY=your-openai-key
QWEN_API_KEY=your-qwen-key

# Runtime
PORT=3000
DEFAULT_AI_PROVIDER=chatgpt
CHATGPT_MODEL=gpt-4o-mini
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
MAX_REQUEST_LOG=300
CUSTOM_RESPONSE=Available
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/1Jh7TXif0dsaAVgoExEOCmkACZHPPZqIsiW4hH8T5Pts/export?format=csv
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://autoresponder.horleytech.com

# Optional Firebase persistence (provider + csv source + request records)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
